{
  "name": "markview-chrome",
  "version": "0.5.2",
  "description": "A Chrome extension that detects raw `.md` / `.markdown` files and renders them with the MarkView engine, providing syntax highlighting, mermaid diagrams, dark/light themes, and a table of contents.",
  "main": "cloud-storage.js",
  "scripts": {
    "build": "esbuild editor/entry.js --bundle --format=iife --outfile=codemirror-bundle.js --minify",
    "build:dev": "esbuild editor/entry.js --bundle --format=iife --outfile=codemirror-bundle.js --sourcemap",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["markdown", "chrome-extension", "viewer", "mermaid"],
  "author": "David Forbes / Forbes Asset Management",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "codemirror": "^6.0.2",
    "esbuild": "^0.27.4"
  }
}
